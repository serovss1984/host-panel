<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель управления - Вход</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'DejaVu Sans', Arial, sans-serif;
        }
        
        body {
            background-color: #242424;
            color: #d8d8d8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-image: linear-gradient(to bottom, #2e2e2e, #1a1a1a);
        }
        
        .login-container {
            background-color: #303030;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
            padding: 30px;
            width: 380px;
            border: 1px solid #404040;
        }
        
        h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #ffffff;
            font-weight: 600;
            font-size: 24px;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
        }
        
        .error-message {
            background-color: #5a3636;
            color: #ff8e8e;
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 20px;
            border-left: 4px solid #ff5252;
            font-size: 14px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #b8b8b8;
            font-size: 14px;
        }
        
        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 12px 15px;
            background-color: #3b3b3b;
            border: 1px solid #454545;
            border-radius: 4px;
            color: #e8e8e8;
            font-size: 15px;
            transition: all 0.3s;
        }
        
        input[type="text"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #4d9aff;
            box-shadow: 0 0 0 2px rgba(77, 154, 255, 0.2);
        }
        
        input[type="text"]::placeholder,
        input[type="password"]::placeholder {
            color: #7a7a7a;
        }
        
        button {
            width: 100%;
            padding: 12px;
            background-color: #3465a4;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s;
            margin-top: 10px;
        }
        
        button:hover {
            background-color: #2c5899;
        }
        
        button:active {
            background-color: #244e87;
        }
        
        .debian-branding {
            text-align: center;
            margin-top: 25px;
            font-size: 12px;
            color: #7a7a7a;
        }
        
        .debian-logo {
            color: #d70751;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h2>Вход в панель управления</h2>
        
        <% if (error) { %>
            <div class="error-message">
                <%= error %>
            </div>
        <% } %>
        
        <form method="post" action="/login">
            <div class="form-group">
                <label for="username">Имя пользователя</label>
                <input type="text" id="username" name="username" placeholder="Введите ваше имя пользователя">
            </div>
            
            <div class="form-group">
                <label for="password">Пароль</label>
                <input type="password" id="password" name="password" placeholder="Введите ваш пароль">
            </div>
            
            <button type="submit">Войти</button>
        </form>
        
        <div class="debian-branding">
            Powered by <span class="debian-logo">RLK Media</span>
        </div>
    </div>
</body>
</html>